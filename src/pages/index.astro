---
import App from "../lib/components/App.svelte";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Edge Extender</title>
  </head>
  <body>
    <App client:load />
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  html,
  body {
    margin: 0;
    padding: 0;
    height: 100%;
    font-family:
      system-ui,
      -apple-system,
      sans-serif;
  }
</style>
