---
import type { Tool } from "$lib/tools";

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<a class="card" href={`/${tool.slug}`}>
  <img class="icon" src={tool.iconHref} alt="" aria-hidden="true" width="64" height="64" />
  <div class="text">
    <h3 class="name">{tool.name}</h3>
    <p class="tagline">{tool.tagline}</p>
  </div>
</a>

<style>
  .card {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1.25rem;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    transition: border-color 120ms ease, box-shadow 120ms ease, transform 120ms ease;
  }
  .card:hover {
    border-color: #9ca3af;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04), 0 4px 12px rgba(0, 0, 0, 0.04);
    transform: translateY(-1px);
  }
  .icon {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    color: #1f2937;
  }
  .text {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .name {
    font-size: 1.05rem;
    font-weight: 600;
    color: #111;
    margin: 0;
  }
  .tagline {
    font-size: 0.875rem;
    color: #4b5563;
    margin: 0;
    line-height: 1.45;
  }
</style>
